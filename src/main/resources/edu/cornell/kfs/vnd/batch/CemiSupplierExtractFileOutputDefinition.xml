        <field name="Use_For_Tenanted_1_1" type="STRING" key="useForTenanted1_1"/>
        <field name="Use_For_Tenanted_1_2" type="STRING" key="useForTenanted1_2"/>
        <field name="Use_For_Tenanted_1_3" type="STRING" key="useForTenanted1_3"/>
        <field name="Use_For_Tenanted_1_4" type="STRING" key="useForTenanted1_4"/>
        <field name="Email_ID_2" type="STRING" key="emailId2"/>
        <field name="Email_Address_2" type="STRING" key="emailAddress2"/>
        <field name="Email_Primary_2" type="STRING" key="emailPrimary2"/>
        <field name="Email_Use_For_2_1" type="STRING" key="emailUseFor2_1"/>
        <field name="Email_Use_For_2_2" type="STRING" key="emailUseFor2_2"/>
        <field name="Email_Use_For_2_3" type="STRING" key="emailUseFor2_3"/>
        <field name="Email_Use_For_2_4" type="STRING" key="emailUseFor2_4"/>
        <field name="Use_For_Tenanted_2_1" type="STRING" key="useForTenanted2_1"/>
        <field name="Use_For_Tenanted_2_2" type="STRING" key="useForTenanted2_2"/>
        <field name="Use_For_Tenanted_2_3" type="STRING" key="useForTenanted2_3"/>
        <field name="Use_For_Tenanted_2_4" type="STRING" key="useForTenanted2_4"/>
        <field name="Email_ID_3" type="STRING" key="emailId3"/>
        <field name="Email_Address_3" type="STRING" key="emailAddress3"/>
        <field name="Email_Primary_3" type="STRING" key="emailPrimary3"/>
        <field name="Email_Use_For_3_1" type="STRING" key="emailUseFor3_1"/>
        <field name="Email_Use_For_3_2" type="STRING" key="emailUseFor3_2"/>
