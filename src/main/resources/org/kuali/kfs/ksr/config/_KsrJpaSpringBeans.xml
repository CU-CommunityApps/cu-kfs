<?xml version="1.0" encoding="UTF-8"?>
<!--
	====
	CU Customization:
	Added this file to configure the KSR module to use JPA instead of OJB.
	Many of the beans here have been copied and tweaked from those in
	the _KewJpaSpringBeans.xml file.
	====
 -->
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:p="http://www.springframework.org/schema/p"
       xmlns:util="http://www.springframework.org/schema/util"
       xmlns:context="http://www.springframework.org/schema/context"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
                           http://www.springframework.org/schema/beans/spring-beans-3.2.xsd
                           http://www.springframework.org/schema/util
                           http://www.springframework.org/schema/util/spring-util-3.2.xsd
                           http://www.springframework.org/schema/context
                           http://www.springframework.org/schema/context/spring-context-3.2.xsd">

  <alias alias="kradApplicationDataSource" name="ksrDataSource" />

  <bean id="jpaPersistenceUnitName" class="java.lang.String">
    <constructor-arg value="ksr" />
  </bean>

  <util:list id="jpaPackagesToScan"/>

  <util:list id="managedClassNames">
    <value>org.kuali.kfs.ksr.bo.SecurityGroup</value>
    <value>org.kuali.kfs.ksr.bo.SecurityGroupTab</value>
    <value>org.kuali.kfs.ksr.bo.SecurityGroupTabId</value>
    <value>org.kuali.kfs.ksr.bo.SecurityProvisioning</value>
    <value>org.kuali.kfs.ksr.bo.SecurityProvisioningGroup</value>
    <value>org.kuali.kfs.ksr.bo.SecurityProvisioningGroupDependentRoles</value>
    <value>org.kuali.kfs.ksr.bo.SecurityProvisioningGroupDependentRolesId</value>
    <value>org.kuali.kfs.ksr.bo.SecurityRequestRole</value>
    <value>org.kuali.kfs.ksr.bo.SecurityRequestRoleId</value>
    <value>org.kuali.kfs.ksr.bo.SecurityRequestRoleQualification</value>
    <value>org.kuali.kfs.ksr.bo.SecurityRequestRoleQualificationId</value>
    <value>org.kuali.kfs.ksr.bo.SecurityRequestRoleQualificationDetail</value>
    <value>org.kuali.kfs.ksr.bo.SecurityRequestRoleQualificationDetailId</value>
    <value>org.kuali.kfs.ksr.document.SecurityRequestDocument</value>
  </util:list>

  <util:list id="additionalMetadataProviders" />
  <util:list id="springMetadataFileLocations" />

  <import resource="classpath:org/kuali/rice/krad/config/KRADSpringBeans-jpa-common.xml" />

  <alias alias="rice.ksr.entityManager" name="sharedEntityManager"/>

</beans>